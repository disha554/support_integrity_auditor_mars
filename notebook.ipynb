)

def resolution_bucket(hours):

    if hours <= 12:
        return 'Low'

    elif hours <= 24:
        return 'Medium'

    elif hours <= 48:
        return 'High'

    else:
        return 'Critical'

df['resolution_severity'] = (
    df['Resolution_Time_Hours']
    .apply(resolution_bucket)
)

df['resolution_severity'].value_counts()

def satisfaction_bucket(score):

    if score <= 2:
        return 'Poor'

    elif score <= 3:
        return 'Average'

    else:
        return 'Good'

df['satisfaction_bucket'] = (
    df['Satisfaction_Score']
    .apply(satisfaction_bucket)
)

critical_keywords = [

'outage',
'server down',
'data loss',
'security breach',
'payment failed',
'fraud',
'hacked',
'cannot access',
'account locked',
'system failure'
]

high_keywords = [

'crash',
'error',
'unable',
'failed',
'urgent',
'broken',
'issue',
'bug'
]

def keyword_score(text):

    text = text.lower()

    score = 0

    for word in critical_keywords:

        if word in text:
            score += 3

    for word in high_keywords:

        if word in text:
            score += 1

    return score

df['keyword_score'] = (
    df['combined_text']
    .apply(keyword_score)
)
df['keyword_score'].describe()

